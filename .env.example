# ── AI provider ───────────────────────────────────────────────────────────────
# AI_PROVIDER selects the LLM backend behind the AiClient interface.
#   mock      → deterministic local generator (default, no network/key needed)
#   anthropic → Anthropic API (requires ANTHROPIC_API_KEY)
#   deepseek  → DeepSeek API, OpenAI-compatible (requires DEEPSEEK_API_KEY)
# A selected provider with a missing key auto-falls back to mock (never hard-fails).
AI_PROVIDER=mock

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# DeepSeek (https://platform.deepseek.com)
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat          # or deepseek-reasoner (R1, deeper reasoning)
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ── Database ────────────────────────────────────────────────────────────────────
# DB_DRIVER selects the storage backend behind the Repository interface.
#   json   → local JSON file at data/store.json (default)
#   memory → ephemeral in-process store (used by tests/eval)
#   sqlite → NOT IMPLEMENTED in v0 (see docs/MOCKS.md) — throws on use
DB_DRIVER=json

# ── Data source (collection pipeline) ───────────────────────────────────────────
# DATA_SOURCE selects the DataFetcher behind the pipeline.
#   mock → fabricated sample dataset (default)
#   real → RealFetcher: reads downloaded official files from DATA_SOURCE_DIR.
#          v0 has a worked example for provincial lines (provincial-lines.csv);
#          other collections are TODO stubs — see src/lib/data/fetchers/realSource.ts
DATA_SOURCE=mock
DATA_SOURCE_DIR=data/sources

# ── Data freshness policy ───────────────────────────────────────────────────────
# Records older than this many days are surfaced as "stale" in the UI.
DATA_STALE_AFTER_DAYS=30
# The "current" admission year the app treats as authoritative.
CURRENT_YEAR=2025
